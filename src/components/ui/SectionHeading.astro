---
interface Props {
  title: string;
  subtitle?: string;
  enTitle?: string;
  align?: 'left' | 'center';
  reveal?: 'chars' | 'fade';
}

const { title, subtitle, enTitle, align = 'left', reveal = 'chars' } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
const titleClass = reveal === 'chars' ? 'char-reveal' : '';
---

<div class:list={['mb-14 max-w-2xl', alignClass]}>
  {enTitle && (
    <div class:list={['flex items-center gap-3 mb-4 reveal', align === 'center' ? 'justify-center' : '']}>
      <span class="block w-8 h-px bg-accent"></span>
      <p class="font-outfit text-[0.6875rem] font-semibold tracking-[0.24em] uppercase text-accent">
        {enTitle}
      </p>
    </div>
  )}
  <h2 class:list={['font-heading text-[var(--font-size-h1)] mb-3 leading-[1.35]', titleClass]}>{title}</h2>
  {subtitle && (
    <p class="text-text-muted text-[var(--font-size-body)] leading-relaxed reveal-blur">{subtitle}</p>
  )}
</div>
