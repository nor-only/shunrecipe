---
import type { Recipe } from '@data/recipes';
import { seasonNames } from '@data/vegetables';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
const seasonInfo = seasonNames[recipe.season];
---

<a href={`/recipes/${recipe.id}/`} class="card block group">
  <div class="recipe-card-image">
    <img
      src={recipe.image}
      alt={recipe.title}
      loading="lazy"
      decoding="async"
    />
    <div class="absolute top-4 left-4">
      <span class:list={['season-badge', `season-badge-${recipe.season}`]}>
        {seasonInfo.jp}
      </span>
    </div>
  </div>
  <div class="p-6">
    <h3 class="font-bold text-lg mb-2 leading-snug group-hover:text-accent transition-colors">
      {recipe.title}
    </h3>
    <p class="text-sm text-text-muted mb-4 line-clamp-2">{recipe.subtitle}</p>
    <div class="flex items-center gap-5 text-xs font-semibold text-text-muted">
      <span class="flex items-center gap-1.5">
        <span class="material-symbols-outlined text-base">schedule</span>
        {recipe.time}分
      </span>
      <span class="flex items-center gap-1.5">
        <span class="material-symbols-outlined text-base">local_fire_department</span>
        {recipe.calories}kcal
      </span>
      <span class="flex items-center gap-1.5">
        <span class="material-symbols-outlined text-base">signal_cellular_alt</span>
        {recipe.difficulty}
      </span>
    </div>
  </div>
</a>
