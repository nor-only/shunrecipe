---
import type { Recipe } from '@data/recipes';
import { seasonNames } from '@data/vegetables';

interface Props {
  recipe: Recipe;
  showFavorite?: boolean;
}

const { recipe, showFavorite = true } = Astro.props;
const seasonInfo = seasonNames[recipe.season];
---

<a href={`/recipes/${recipe.id}/`} class="card block group relative">
  {showFavorite && (
    <button
      type="button"
      class="fav-toggle fav-card-button"
      data-fav-id={recipe.id}
      aria-label="お気に入りに追加"
    >
      <span class="material-symbols-outlined text-lg">favorite</span>
    </button>
  )}

  <div class="recipe-card-image">
    <img
      src={recipe.image}
      alt={recipe.title}
      loading="lazy"
      decoding="async"
    />
    <div class="recipe-card-overlay">
      <span class:list={['season-badge', `season-badge-${recipe.season}`]}>
        {seasonInfo.jp}
      </span>
    </div>
  </div>

  <div class="p-6">
    <h3 class="font-heading text-[1.0625rem] mb-2 leading-snug group-hover:text-accent transition-colors line-clamp-2">
      {recipe.title}
    </h3>
    <p class="text-[0.8125rem] text-text-muted mb-5 line-clamp-2 leading-relaxed">{recipe.subtitle}</p>

    <div class="flex items-center gap-4 text-[0.6875rem] font-semibold text-text-muted uppercase tracking-wider font-mono-num">
      <span class="flex items-center gap-1">
        <span class="material-symbols-outlined" style="font-size:14px">schedule</span>
        {recipe.time}min
      </span>
      <span class="flex items-center gap-1">
        <span class="material-symbols-outlined" style="font-size:14px">local_fire_department</span>
        {recipe.calories}kcal
      </span>
      <span class="flex items-center gap-1">
        <span class="material-symbols-outlined" style="font-size:14px">restaurant</span>
        {recipe.servings}人
      </span>
    </div>
  </div>
</a>
