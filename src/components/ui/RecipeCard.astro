---
import { regionName } from '@data/regions';

interface Props {
  id: string;
  title: string;
  season: 'spring'|'summer'|'autumn'|'winter';
  region?: string;
  genre?: string;
  time_min: number;
  hero_image: string;
  wide?: boolean;
}
const { id, title, season, region, genre = '和', time_min, hero_image, wide = false } = Astro.props;
const seasonJp = { spring: '春', summer: '夏', autumn: '秋', winter: '冬' }[season];
---
<a href={`/recipes/${id}/`} class={`ed-card ${wide ? 'ed-card-wide' : ''}`} data-recipe={id}>
  <div class="media">
    <img src={hero_image} alt={title} loading="lazy" decoding="async" />
  </div>
  <div class="rule"></div>
  <div class="meta">
    <span class="genre">{genre} · {time_min}min</span>
    <span class={`genre accent-${season}`}><span class="season-dot"></span>{seasonJp}</span>
  </div>
  <h3 class="title">{title}</h3>
  {region && <p style="font-family: var(--font-serif-jp); font-size: 0.8125rem; color: var(--color-ink-3); letter-spacing: 0.04em;">{regionName(region)}</p>}
</a>
