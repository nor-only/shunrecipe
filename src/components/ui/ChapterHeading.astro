---
interface Props {
  num: string;
  title: string;
  lede?: string;
  caption?: string;
}
const { num, title, lede, caption } = Astro.props;
---
<header class="chapter-heading reveal">
  <p class="num">{num}</p>
  <hr class="rule-accent" />
  <h2 class="title">{title}</h2>
  {caption && <p class="caption-en">{caption}</p>}
  {lede && <p class="lede">{lede}</p>}
</header>
