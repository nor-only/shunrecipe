---
import { getCollection } from 'astro:content';
import { wafuLabel } from '@/lib/date';

interface Props {
  images?: string[];
  title?: string;
  lede?: string;
  edition?: string;
}

const vegetables = await getCollection('vegetables');
const now = new Date();
const monthIdx = now.getMonth() + 1;
const monthToSeason = (m: number): 'spring'|'summer'|'autumn'|'winter' =>
  (m >= 3 && m <= 5) ? 'spring' : (m >= 6 && m <= 8) ? 'summer' : (m >= 9 && m <= 11) ? 'autumn' : 'winter';
const currentSeason = monthToSeason(monthIdx);
const seasonJp = { spring: '春', summer: '夏', autumn: '秋', winter: '冬' }[currentSeason];

// Default: pull a handful of hero-worthy shots from existing recipe images.
const {
  images = [
    '/assets/images/takenoko_rice.png',
    '/assets/images/nasu_miso.png',
    '/assets/images/ratatouille.png',
    '/assets/images/kinoko_ahijo.png',
    '/assets/images/millefeuille_nabe.png',
    '/assets/images/daikon_furofuki.png',
    '/assets/images/corn_rice.png',
    '/assets/images/satsumaimo_gratin.png',
  ],
  title = '旬を知る、\n食を編み直す。',
  lede = '全国八地域と四季が育む野菜を、\n編集者の眼で選び、一冊の誌面のように綴じました。',
  edition = wafuLabel(now),
} = Astro.props;

const featured = vegetables
  .filter((v) => v.data.seasons.includes(currentSeason))
  .slice(0, 4);

void featured; // reserved for a future in-hero overlay
---

<section class="hero-ed" aria-label="Hero">
  <div class="bg" data-hero-bg>
    {images.map((src, i) => (
      <div class={`slide ${i === 0 ? 'is-active' : ''}`} data-slide>
        <img src={src} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" width="2560" height="1440" />
      </div>
    ))}
    <div class="veil"></div>
  </div>

  <div class="content">
    <div class="container-wide content-wrap reveal">
      <div class="edition">
        <span>{edition}</span>
        <span>A Seasonal Recipe Journal</span>
      </div>
      <div class="hero-rule"></div>
      <h1>
        {title.split('\n').map((line, i) => (
          <Fragment>
            {i > 0 && <br />}
            {line}
          </Fragment>
        ))}
      </h1>
      <p class="lede">
        {lede.split('\n').map((line, i) => (
          <Fragment>
            {i > 0 && <br />}
            {line}
          </Fragment>
        ))}
      </p>

      <div style="display:flex; gap: 1rem; flex-wrap: wrap; padding-top: 0.5rem;">
        <a class="ed-btn is-inverse" href="/recipes/">レシピ総覧</a>
        <a class="ed-btn is-inverse" href="/seasonal/">{seasonJp}の図鑑</a>
      </div>
    </div>
  </div>
</section>

<script>
  function initHeroSlideshow() {
    try {
      const section = document.querySelector<HTMLElement>('.hero-ed');
      if (!section) { console.debug('[hero] no section'); return; }
      const slides = Array.from(section.querySelectorAll<HTMLElement>('[data-slide]'));
      if (slides.length < 2) { console.debug('[hero] < 2 slides'); return; }
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) { console.debug('[hero] reduced motion'); return; }

      const order = slides.map((_, i) => i);
      for (let i = order.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [order[i], order[j]] = [order[j], order[i]];
      }

      slides.forEach((s) => s.classList.remove('is-active'));
      slides[order[0]].classList.add('is-active');

      let idx = 0;
      const hold = () => 7000 + Math.random() * 2000;
      const tick = () => {
        const prev = order[idx];
        idx = (idx + 1) % order.length;
        const next = order[idx];
        slides[prev].classList.remove('is-active');
        slides[next].classList.add('is-active');
        window.setTimeout(tick, hold());
      };
      window.setTimeout(tick, hold());
      console.debug('[hero] slideshow started with', slides.length, 'slides');
    } catch (err) {
      console.error('[hero] error:', err);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroSlideshow);
  } else {
    initHeroSlideshow();
  }
</script>
