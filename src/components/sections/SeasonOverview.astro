---
import { seasonNames, getVegetablesBySeason } from '@data/vegetables';
import SectionHeading from '@components/ui/SectionHeading.astro';

const seasons = Object.entries(seasonNames) as [
  string,
  { jp: string; en: string; months: string; color: string }
][];
---

<section class="section-padding bg-bg-muted">
  <div class="container-site">
    <SectionHeading
      enTitle="Four Seasons"
      title="四季の恵みを編む"
      subtitle="日本の四季それぞれに、その時期だけの旬野菜があります。各季節の入口から、お好きな旬を辿ってください。"
      align="center"
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 stagger-children">
      {seasons.map(([key, info]) => {
        const vegs = getVegetablesBySeason(key as any);
        return (
          <a
            href={`/seasonal/?season=${key}`}
            class="card block p-8 group transition-all"
          >
            <div class="flex items-start justify-between mb-6">
              <div>
                <p class="font-outfit text-[0.6875rem] tracking-[0.2em] uppercase font-semibold mb-2" style={`color: ${info.color}`}>
                  {info.en}
                </p>
                <h3 class="font-heading text-[1.5rem] leading-tight">{info.jp}</h3>
              </div>
              <span class="text-2xl opacity-70">
                {key === 'spring' ? '\u{1F338}' : key === 'summer' ? '\u{2600}\u{FE0F}' : key === 'autumn' ? '\u{1F341}' : '\u{2744}\u{FE0F}'}
              </span>
            </div>
            <div class="space-y-1.5 mb-5">
              <p class="text-[0.75rem] text-text-muted font-outfit tracking-wide">{info.months}</p>
              <p class="text-[0.75rem] text-text-muted font-mono-num">{vegs.length} vegetables</p>
            </div>
            <div class="flex items-center gap-2 text-[0.75rem] tracking-wider uppercase font-outfit text-text group-hover:text-accent transition-colors">
              <span>View season</span>
              <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
