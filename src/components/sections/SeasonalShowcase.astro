---
import VegCard from '@components/ui/VegCard.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { getCurrentSeason, getVegetablesBySeason, seasonNames } from '@data/vegetables';

const season = getCurrentSeason();
const vegs = getVegetablesBySeason(season);
const info = seasonNames[season];
---

<section class="section-padding bg-bg-warm">
  <div class="container-site">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="reveal max-w-xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-accent"></span>
          <p class="font-outfit text-[0.6875rem] font-semibold tracking-[0.24em] uppercase text-accent">
            In Season — {info.en}
          </p>
        </div>
        <h2 class="font-heading text-[var(--font-size-h1)] mb-3 leading-[1.35] char-reveal">
          いま、{info.jp}の旬を味わう。
        </h2>
        <p class="text-text-muted text-[var(--font-size-body)] leading-relaxed">
          {info.months}が旬の野菜は、栄養価も風味も最も高まる季節。日本の地域ごとに育まれた恵みをご紹介します。
        </p>
      </div>
      <a href="/seasonal/" class="btn-ghost reveal self-start lg:self-end whitespace-nowrap">
        すべての旬野菜
        <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
      </a>
    </div>

    <div class="grid-vegetables stagger-children">
      {vegs.slice(0, 5).map(v => (
        <VegCard vegetable={v} />
      ))}
    </div>
  </div>
</section>
