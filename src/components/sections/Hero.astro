---
import { getCurrentSeason, seasonNames, getVegetablesBySeason } from '@data/vegetables';

const season = getCurrentSeason();
const info = seasonNames[season];
const seasonalVegs = getVegetablesBySeason(season).slice(0, 4);
const today = new Date();
const dateLabel = `${today.getFullYear()} / ${String(today.getMonth() + 1).padStart(2, '0')} / ${String(today.getDate()).padStart(2, '0')}`;
---

<section class="relative min-h-[100svh] flex flex-col overflow-hidden bg-primary">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/pumpkin_soup.png"
      alt=""
      class="w-full h-full object-cover scale-[1.04]"
      style="object-position: center 50%; animation: heroZoom 28s infinite alternate linear;"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(15,20,25,0.7) 0%, rgba(15,20,25,0.4) 35%, rgba(15,20,25,0.95) 100%);"></div>
    <div class="absolute inset-0 hidden md:block" style="background: linear-gradient(90deg, rgba(15,20,25,0.55) 0%, transparent 55%);"></div>
  </div>

  <!-- Subtle Grid -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-30"
       style="background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Content wrapper: 3 rows for date strip / spacer / content -->
  <div class="relative z-10 flex-1 flex flex-col w-full pt-[clamp(7rem,16vh,10rem)] pb-[clamp(5rem,12vh,8rem)]">
    <!-- Top date strip -->
    <div class="container-site">
      <div class="flex items-center justify-between text-white/45 text-[0.625rem] sm:text-[0.6875rem] tracking-[0.18em] sm:tracking-[0.2em] uppercase font-outfit gap-4">
        <span class="truncate">Edition · {dateLabel}</span>
        <span class="hidden lg:inline whitespace-nowrap">No. 001 — A Seasonal Recipe Journal</span>
      </div>
    </div>

    <!-- Main content (pushed to bottom) -->
    <div class="container-site mt-auto pt-12">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-8 lg:items-end">
        <div class="lg:col-span-7 xl:col-span-8">
          <div class="flex items-center gap-3 mb-5 reveal">
            <span class="block w-8 h-px bg-accent-glow"></span>
            <p class="font-outfit text-[0.625rem] sm:text-[0.6875rem] font-semibold tracking-[0.24em] sm:tracking-[0.28em] uppercase text-accent-glow">
              A Seasonal Recipe Journal
            </p>
          </div>

          <h1 class="font-heading text-white leading-[1.15] tracking-tight mb-6 sm:mb-8 reveal text-[clamp(2rem,8vw,4.75rem)]">
            旬を知る、<br />
            食を編み直す。
          </h1>

          <p class="text-[0.9375rem] sm:text-base md:text-lg text-white/65 max-w-lg leading-relaxed mb-8 sm:mb-10 reveal">
            日本の四季と地域が育む旬の野菜と、<br class="hidden sm:block lg:hidden xl:block" />
            その魅力を最大限に引き出すレシピ。<br />
            毎日の食卓を、ひとつ上の体験へ。
          </p>

          <div class="flex flex-col sm:flex-row gap-3 reveal">
            <a href="/recipes/" class="btn-primary">
              <span>レシピを見る</span>
              <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
            </a>
            <a href="/seasonal/" class="btn-outline border-white/30 text-white hover:border-white hover:text-white">
              四季の図鑑
            </a>
          </div>
        </div>

        <!-- Right info card -->
        <div class="lg:col-span-5 xl:col-span-4 reveal">
          <div class="bg-white/[0.06] backdrop-blur-md border border-white/10 rounded-[var(--radius-lg)] p-6 sm:p-7">
            <p class="text-[0.625rem] sm:text-[0.6875rem] font-outfit tracking-[0.2em] uppercase text-white/40 mb-3">In Season Now</p>
            <p class="font-heading text-xl sm:text-2xl text-white mb-1">{info.jp}の旬</p>
            <p class="text-[0.75rem] text-white/50 mb-5 font-outfit tracking-wide">{info.en} · {info.months}</p>

            <div class="space-y-1 mb-5">
              {seasonalVegs.map(v => (
                <a href={`/vegetables/${v.id}/`} class="flex items-center justify-between text-[0.8125rem] sm:text-[0.875rem] text-white/80 hover:text-white py-2 border-b border-white/10 last:border-0 transition-colors">
                  <span class="flex items-center gap-2 min-w-0">
                    <span class="text-base shrink-0">{v.emoji}</span>
                    <span class="truncate">{v.name}</span>
                  </span>
                  <span class="material-symbols-outlined text-white/30 shrink-0" style="font-size:16px">arrow_forward</span>
                </a>
              ))}
            </div>

            <a href="/seasonal/" class="text-[0.6875rem] sm:text-[0.75rem] tracking-wider uppercase font-outfit text-accent-glow hover:text-white transition-colors flex items-center gap-2">
              すべての旬野菜を見る
              <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 text-white/40 scroll-indicator hidden sm:flex">
    <span class="text-[0.625rem] font-outfit tracking-[0.3em]">SCROLL</span>
    <span class="scroll-indicator-line"></span>
  </div>
</section>

<style>
  @keyframes heroZoom {
    from { transform: scale(1.02); }
    to { transform: scale(1.12); }
  }
</style>
