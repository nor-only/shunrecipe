---
import { getCurrentSeason, seasonNames, getVegetablesBySeason } from '@data/vegetables';

const season = getCurrentSeason();
const info = seasonNames[season];
const seasonalVegs = getVegetablesBySeason(season).slice(0, 4);
const today = new Date();
const dateLabel = `${today.getFullYear()} / ${String(today.getMonth() + 1).padStart(2, '0')} / ${String(today.getDate()).padStart(2, '0')}`;

// Crossfade slideshow — images cycle creating a video-like ambient motion
const heroImages = [
  '/assets/images/pumpkin_soup.png',
  '/assets/images/asparagus_cheese.png',
  '/assets/images/ratatouille.png',
  '/assets/images/nasu_miso.png',
];
---

<section class="hero-section relative min-h-[100svh] flex flex-col overflow-hidden bg-primary">
  <!-- Background: cinematic crossfade slideshow -->
  <div class="absolute inset-0 z-0 parallax-wrap">
    <div class="hero-slideshow absolute inset-0">
      {heroImages.map((src, i) => (
        <div class="hero-slide" style={`animation-delay: ${i * 6}s;`}>
          <img
            src={src}
            alt=""
            class="w-full h-full object-cover"
            style="object-position: center 50%;"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}
    </div>
    <!-- Ambient light overlay -->
    <div class="hero-light absolute inset-0 pointer-events-none"></div>
    <!-- Vignette + tone -->
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(15,20,25,0.78) 0%, rgba(15,20,25,0.42) 35%, rgba(15,20,25,0.97) 100%);"></div>
    <div class="absolute inset-0 hidden md:block" style="background: linear-gradient(90deg, rgba(15,20,25,0.62) 0%, transparent 55%);"></div>
  </div>

  <!-- Subtle Grid -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-25"
       style="background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Content wrapper -->
  <div class="relative z-10 flex-1 flex flex-col w-full pt-[clamp(6.5rem,15vh,10rem)] pb-[clamp(4rem,10vh,7rem)]">
    <!-- Top date strip -->
    <div class="container-site">
      <div class="flex items-center justify-between text-white/45 text-[0.625rem] sm:text-[0.6875rem] tracking-[0.18em] sm:tracking-[0.2em] uppercase font-outfit gap-4 reveal">
        <span class="truncate">Edition · {dateLabel}</span>
        <span class="hidden lg:inline whitespace-nowrap">No. 001 — A Seasonal Recipe Journal</span>
      </div>
    </div>

    <!-- Main content -->
    <div class="container-site mt-auto pt-10 sm:pt-12">
      <div class="grid lg:grid-cols-12 gap-8 sm:gap-10 lg:gap-8 lg:items-end">
        <div class="lg:col-span-7 xl:col-span-8">
          <div class="flex items-center gap-3 mb-5 sm:mb-6 reveal">
            <span class="block w-8 h-px bg-accent-glow"></span>
            <p class="font-outfit text-[0.625rem] sm:text-[0.6875rem] font-semibold tracking-[0.24em] sm:tracking-[0.28em] uppercase text-accent-glow">
              A Seasonal Recipe Journal
            </p>
          </div>

          <h1 class="font-heading text-white leading-[1.15] tracking-tight mb-6 sm:mb-8 text-[clamp(2rem,8vw,4.75rem)]">
            <span class="char-reveal block" data-char-scrub="false">旬を知る、</span>
            <span class="char-reveal block" data-char-scrub="false">食を編み直す。</span>
          </h1>

          <p class="text-[0.9375rem] sm:text-base md:text-lg text-white/65 max-w-lg leading-relaxed mb-8 sm:mb-10 reveal-blur">
            日本の四季と地域が育む旬の野菜と、<br class="hidden sm:block lg:hidden xl:block" />
            その魅力を最大限に引き出すレシピ。<br />
            毎日の食卓を、ひとつ上の体験へ。
          </p>

          <div class="flex flex-col sm:flex-row gap-3 reveal">
            <a href="/recipes/" class="btn-primary">
              <span>レシピを見る</span>
              <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
            </a>
            <a href="/seasonal/" class="btn-outline border-white/30 text-white hover:border-white hover:text-white">
              四季の図鑑
            </a>
          </div>
        </div>

        <!-- Right info card -->
        <div class="lg:col-span-5 xl:col-span-4 reveal-blur">
          <div class="bg-white/[0.06] backdrop-blur-md border border-white/10 rounded-[var(--radius-lg)] p-6 sm:p-7">
            <p class="text-[0.625rem] sm:text-[0.6875rem] font-outfit tracking-[0.2em] uppercase text-white/40 mb-3">In Season Now</p>
            <p class="font-heading text-xl sm:text-2xl text-white mb-1">{info.jp}の旬</p>
            <p class="text-[0.75rem] text-white/50 mb-5 font-outfit tracking-wide">{info.en} · {info.months}</p>

            <div class="space-y-1 mb-5">
              {seasonalVegs.map(v => (
                <a href={`/vegetables/${v.id}/`} class="flex items-center justify-between text-[0.8125rem] sm:text-[0.875rem] text-white/80 hover:text-white py-2 border-b border-white/10 last:border-0 transition-colors">
                  <span class="flex items-center gap-2 min-w-0">
                    <span class="text-base shrink-0">{v.emoji}</span>
                    <span class="truncate">{v.name}</span>
                  </span>
                  <span class="material-symbols-outlined text-white/30 shrink-0" style="font-size:16px">arrow_forward</span>
                </a>
              ))}
            </div>

            <a href="/seasonal/" class="text-[0.6875rem] sm:text-[0.75rem] tracking-wider uppercase font-outfit text-accent-glow hover:text-white transition-colors flex items-center gap-2">
              すべての旬野菜を見る
              <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 text-white/40 scroll-indicator hidden sm:flex">
    <span class="text-[0.625rem] font-outfit tracking-[0.3em]">SCROLL</span>
    <span class="scroll-indicator-line"></span>
  </div>
</section>

<style>
  /* === Slideshow: each slide fades in/out, combined with Ken Burns === */
  .hero-slideshow { position: absolute; inset: 0; }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: heroCrossfade 24s infinite;
    will-change: opacity, transform;
  }

  .hero-slide img {
    transform-origin: 55% 50%;
    animation: heroKenBurns 24s ease-in-out infinite;
    will-change: transform;
  }

  /* 4 slides × 6s each = 24s cycle. Each slide fades up 0-5%, holds, fades out 25%-30% */
  @keyframes heroCrossfade {
    0%, 25%   { opacity: 1; }
    30%, 95%  { opacity: 0; }
    100%      { opacity: 1; }
  }

  @keyframes heroKenBurns {
    0%   { transform: scale(1.04) translate3d(0, 0, 0); }
    50%  { transform: scale(1.14) translate3d(-1.5%, -1%, 0); }
    100% { transform: scale(1.08) translate3d(1%, 1.5%, 0); }
  }

  /* Ambient light */
  .hero-light {
    background:
      radial-gradient(ellipse 60% 40% at 30% 20%, rgba(255, 220, 170, 0.12), transparent 70%),
      radial-gradient(ellipse 50% 60% at 80% 80%, rgba(120, 180, 255, 0.06), transparent 70%);
    mix-blend-mode: screen;
    animation: heroLight 18s ease-in-out infinite alternate;
  }

  @keyframes heroLight {
    0%   { opacity: 0.8; transform: translate3d(0, 0, 0); }
    100% { opacity: 1; transform: translate3d(-3%, -2%, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide, .hero-slide img, .hero-light { animation: none; }
    .hero-slide:first-child { opacity: 1; }
  }
</style>
