---
import RecipeCard from '@components/ui/RecipeCard.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { recipes } from '@data/recipes';
import { getCurrentSeason } from '@data/vegetables';

const season = getCurrentSeason();
const seasonalRecipes = recipes.filter(r => r.season === season).slice(0, 6);
const featured = seasonalRecipes.length >= 3 ? seasonalRecipes : recipes.slice(0, 6);
---

<section class="section-padding">
  <div class="container-site">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="reveal max-w-xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-accent"></span>
          <p class="font-outfit text-[0.6875rem] font-semibold tracking-[0.24em] uppercase text-accent">
            Editor's Selection
          </p>
        </div>
        <h2 class="font-heading text-[var(--font-size-h1)] mb-3 leading-[1.35] char-reveal">
          編集部が選ぶ、今夜のひと皿。
        </h2>
        <p class="text-text-muted text-[var(--font-size-body)] leading-relaxed">
          季節の食材を活かした、編集部厳選のレシピ。作り方の手順も手元に置きやすい設計です。
        </p>
      </div>
      <a href="/recipes/" class="btn-ghost reveal self-start lg:self-end whitespace-nowrap">
        すべてのレシピ
        <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
      </a>
    </div>

    <div class="grid-recipes stagger-children">
      {featured.slice(0, 6).map(r => (
        <RecipeCard recipe={r} />
      ))}
    </div>
  </div>
</section>
