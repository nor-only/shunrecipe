---
const links = [
  { href: '/', label: 'ホーム', icon: 'home' },
  { href: '/seasonal/', label: '四季の図鑑', icon: 'eco' },
  { href: '/recipes/', label: 'レシピ', icon: 'menu_book' },
];
---

<div class="nav-overlay">
  <div class="flex flex-col items-center justify-center h-full gap-8">
    <a href="/" class="flex items-center gap-3 mb-12">
      <span class="material-symbols-outlined text-4xl text-accent" style="font-variation-settings: 'wght' 400;">psychiatry</span>
      <span class="font-outfit text-2xl font-extrabold tracking-[0.15em] text-white">SHUNRECIPE</span>
    </a>

    {links.map((link, i) => (
      <a
        href={link.href}
        class="nav-link flex items-center gap-4"
        style={`transition-delay: ${(i + 1) * 0.08}s`}
      >
        <span class="material-symbols-outlined text-accent">{link.icon}</span>
        {link.label}
      </a>
    ))}
  </div>
</div>
