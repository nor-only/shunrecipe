---
interface Props {
  darkHero?: boolean;
}
const { darkHero = false } = Astro.props;
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/seasonal/', label: '四季の図鑑' },
  { href: '/recipes/', label: 'レシピ' },
  { href: '/favorites/', label: 'お気に入り' },
];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class={`ed-header ${darkHero ? 'on-dark' : ''}`}>
  <div class="container-wide bar">
    <a href="/" class="brand">
      SHUNRECIPE<span class="en">shun · recipe</span>
    </a>
    <nav aria-label="Primary" class="ed-nav-links">
      {links.slice(1).map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'is-active' : ''}>{l.label}</a>
      ))}
    </nav>
    <button type="button" class="ed-hamburger" aria-label="メニューを開く" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="ed-overlay" role="dialog" aria-modal="true" aria-label="ナビゲーション">
  <ul>
    {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
  </ul>
</div>
