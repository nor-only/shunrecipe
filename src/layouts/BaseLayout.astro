---
import '@/styles/editorial.css';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';

interface Props {
  title: string;
  description?: string;
  darkHero?: boolean;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = '日本の四季と地域が育む旬の野菜と、その魅力を最大限に引き出すレシピ。',
  darkHero = false,
  ogImage,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og/default.png', Astro.site).href;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SHUNRECIPE',
  url: canonicalURL.origin,
  description: '日本の四季と地域の旬野菜・プレミアムレシピの編纂誌。',
  inLanguage: 'ja-JP',
};

const ldArray = Array.isArray(jsonLd)
  ? [websiteLd, ...jsonLd]
  : jsonLd
    ? [websiteLd, jsonLd]
    : [websiteLd];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="SHUNRECIPE" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/assets/favicon/favicon.svg" />
    <meta name="theme-color" content="#1C1A17" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    {ldArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main</a>
    <Header darkHero={darkHero} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <div id="globalToast" role="status" aria-live="polite" class="ed-toast"></div>

    <script>
      import Lenis from 'lenis';

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        const lenis = new Lenis({
          duration: 1.15,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          gestureOrientation: 'vertical' as const,
          smoothWheel: true,
        });
        function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
        (window as any).__lenis = lenis;
      }

      function initReveal() {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -8% 0px' },
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }

      function initHeader() {
        const header = document.querySelector('.ed-header');
        if (!header) return;
        const onScroll = () => {
          if (window.scrollY > 40) header.classList.add('is-scrolled');
          else header.classList.remove('is-scrolled');
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      function initNav() {
        const toggle = document.querySelector('[data-nav-toggle]');
        const overlay = document.querySelector('.ed-overlay');
        if (!toggle || !overlay) return;
        toggle.addEventListener('click', () => {
          const open = overlay.classList.toggle('is-open');
          toggle.setAttribute('aria-expanded', String(open));
          document.body.classList.toggle('no-scroll', open);
        });
        overlay.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            overlay.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('no-scroll');
          });
        });
      }

      // --- Favorites store ---
      const FAV_KEY = 'shunrecipe.favorites';
      function getFavs(): string[] {
        try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
      }
      function setFavs(ids: string[]) {
        localStorage.setItem(FAV_KEY, JSON.stringify(ids));
        document.dispatchEvent(new CustomEvent('favorites:change', { detail: ids }));
      }
      function toggleFav(id: string): boolean {
        const favs = getFavs();
        const i = favs.indexOf(id);
        if (i === -1) favs.push(id); else favs.splice(i, 1);
        setFavs(favs);
        return i === -1;
      }
      function toast(msg: string) {
        const el = document.getElementById('globalToast');
        if (!el) return;
        el.textContent = msg;
        el.classList.add('is-visible');
        setTimeout(() => el.classList.remove('is-visible'), 2000);
      }
      (window as any).__shunrecipe = { getFavs, toggleFav, toast };

      function initFavs() {
        const favs = new Set(getFavs());
        document.querySelectorAll<HTMLElement>('[data-fav-id]').forEach((btn) => {
          const id = btn.dataset.favId!;
          if (favs.has(id)) btn.classList.add('is-active');
          btn.addEventListener('click', (ev) => {
            ev.preventDefault();
            ev.stopPropagation();
            const on = toggleFav(id);
            btn.classList.toggle('is-active', on);
            toast(on ? 'お気に入りに追加しました' : 'お気に入りから外しました');
          });
        });
      }

      function init() {
        initReveal();
        initHeader();
        initNav();
        initFavs();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

    <style is:global>
      .ed-toast {
        position: fixed;
        bottom: 2rem; left: 50%;
        transform: translateX(-50%) translateY(20px);
        padding: 0.75rem 1.4rem;
        background: var(--color-ink);
        color: var(--color-bg);
        font-family: var(--font-serif-jp);
        font-size: 0.875rem;
        letter-spacing: 0.06em;
        opacity: 0;
        pointer-events: none;
        transition: opacity 260ms, transform 260ms;
        z-index: 100;
      }
      .ed-toast.is-visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      [data-fav-id] {
        width: 36px; height: 36px;
        display: inline-flex; align-items: center; justify-content: center;
        border: 1px solid var(--color-line);
        background: transparent;
        cursor: pointer;
        transition: background 220ms, border-color 220ms;
      }
      [data-fav-id] svg { width: 14px; height: 14px; stroke: var(--color-ink-2); fill: transparent; stroke-width: 1px; }
      [data-fav-id]:hover { border-color: var(--color-ink); }
      [data-fav-id].is-active { background: var(--color-ink); border-color: var(--color-ink); }
      [data-fav-id].is-active svg { stroke: var(--color-bg); fill: var(--color-bg); }
    </style>
  </body>
</html>
