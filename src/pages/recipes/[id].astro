---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import RecipeCard from '@components/ui/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { regionName } from '@data/regions';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((r) => ({ params: { id: r.data.id }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const d = recipe.data;
const seasonJp = { spring: '春', summer: '夏', autumn: '秋', winter: '冬' }[d.season];
const diffLabel = ({ 1: 'かんたん', 2: 'ふつう', 3: 'むずかしい' } as const)[d.difficulty as 1|2|3];

const all = await getCollection('recipes');
const related = all
  .filter((r) => r.data.id !== d.id && (r.data.season === d.season || r.data.region === d.region))
  .slice(0, 4);

const cuisineMap: Record<string, string> = {
  '和': 'Japanese',
  '洋': 'Western',
  '中': 'Chinese',
  'エスニック': 'Ethnic',
  '創作': 'Fusion',
};

const ldDescription = d.story || d.subtitle || '';
const metaDescription = d.subtitle || (d.story ? d.story.slice(0, 120) : '');
// Prefecture recipes have no templated OG; fall back to the hero photo.
const ogImage = d.id.startsWith('r_pref_') ? d.hero_image : `/og/recipe-${d.id}.png`;

const recipeLd = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: d.title,
  description: ldDescription,
  image: [new URL(d.hero_image, Astro.site).href],
  author: {
    '@type': 'Organization',
    name: 'SHUNRECIPE',
    url: new URL('/', Astro.site).href,
  },
  recipeCategory: d.genre,
  recipeCuisine: cuisineMap[d.genre] ?? d.genre,
  totalTime: `PT${d.time_min}M`,
  recipeYield: `${d.servings}人前`,
  keywords: d.tags?.join(', '),
  recipeIngredient: d.ingredients.map((i) => `${i.name} ${i.amount}`),
  recipeInstructions: d.steps.map((s, idx) => ({
    '@type': 'HowToStep',
    position: idx + 1,
    text: s,
  })),
  nutrition: d.calories ? { '@type': 'NutritionInformation', calories: `${d.calories} kcal` } : undefined,
};
---
<BaseLayout
  title={`${d.title} — SHUNRECIPE`}
  description={metaDescription}
  ogImage={ogImage}
  jsonLd={recipeLd}
>
  <article>
    <div class="container-site">
      <nav style="padding-top: clamp(6rem, 12vw, 9rem); display: flex; gap: 1.5rem; align-items: baseline;">
        <a href="/recipes/" class="ed-link" style="font-size: 0.8125rem;"><span class="arrow">←——</span> レシピ総覧</a>
        <span class="meta-inline">{d.genre} · {seasonJp} · {d.region ? regionName(d.region) : '日本各地'}</span>
      </nav>

      <header class="recipe-hero">
        <div>
          <p class="chapter-num">Recipe · No. {d.id.replace(/^r_/, '').toUpperCase()}</p>
          <hr class="rule-accent" style="margin: 1rem 0;" />
          <h1 class="display-2" style="margin-bottom: 1rem;">{d.title}</h1>
          {d.subtitle && <p class="caption-en" style="font-size: 1rem; font-variant: normal; font-style: italic;">{d.subtitle}</p>}
          {d.story && (
            <p style="margin-top: 1.75rem; font-family: var(--font-serif-jp); line-height: 2; color: var(--color-ink-2); max-width: 52ch;">
              {d.story}
            </p>
          )}
        </div>
        <div class="media">
          <img src={d.hero_image} alt={d.title} />
        </div>
      </header>

      <section class="spec-list" aria-label="レシピ諸元">
        <div>
          <p class="k">Time</p>
          <p class="v">{d.time_min}分</p>
        </div>
        <div>
          <p class="k">Serves</p>
          <p class="v">{d.servings}人前</p>
        </div>
        <div>
          <p class="k">Level</p>
          <p class="v">{diffLabel}</p>
        </div>
        <div>
          <p class="k">Calories</p>
          <p class="v">{d.calories ? `${d.calories}kcal` : '—'}</p>
        </div>
      </section>

      <section class="ed-body" style="padding-block: clamp(2.5rem, 6vw, 5rem);">
        <div>
          <h2 class="h-section" style="margin-bottom: 1.25rem;">手順</h2>
          <hr class="rule-accent" style="margin-bottom: 1.75rem;" />
          <ol class="steps-list">
            {d.steps.map((s) => <li><p>{s}</p></li>)}
          </ol>

          {d.tips && (
            <div style="margin-top: 3rem; padding: 1.75rem; border-left: 2px solid var(--color-ink); background: var(--color-bg-warm);">
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Editor's note</p>
              <p style="font-family: var(--font-serif-jp); line-height: 1.9;">{d.tips}</p>
            </div>
          )}
        </div>

        <aside>
          <h2 class="h-section" style="margin-bottom: 1.25rem;">材料</h2>
          <hr class="rule-accent" style="margin-bottom: 1rem;" />
          <table class="ingredients-table">
            <tbody>
              {d.ingredients.map((i) => (
                <tr>
                  <td>{i.name}</td>
                  <td>{i.amount}</td>
                  <td style="width: 48px; text-align: right;">
                    <button
                      type="button"
                      class="shop-add"
                      data-shop-add
                      data-shop-name={i.name}
                      data-shop-amount={i.amount}
                      data-shop-recipe-id={d.id}
                      data-shop-recipe-title={d.title}
                      aria-label={`${i.name} を買い物リストへ追加`}
                      title="買い物リストへ追加"
                    >
                      +
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div style="margin-top: 1rem; display:flex; gap: 0.75rem; flex-wrap: wrap;">
            <button type="button" class="ed-btn" data-shop-add-all>すべて買い物リストへ</button>
            <a href="/shopping/" class="ed-link" style="align-self:center;">買い物リストを開く<span class="arrow">——→</span></a>
          </div>

          {d.pairing_wine && d.pairing_wine.length > 0 && (
            <div style="margin-top: 2.5rem;">
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Pairing</p>
              <p style="font-family: var(--font-serif-jp); line-height: 1.9;">{d.pairing_wine.join(' / ')}</p>
            </div>
          )}

          {d.tags && d.tags.length > 0 && (
            <div style="margin-top: 2rem;">
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Tags</p>
              <div style="display:flex; flex-wrap:wrap; gap: 0.5rem;">
                {d.tags.map((t) => <span class="pill" style="pointer-events:none;">{t}</span>)}
              </div>
            </div>
          )}

          <div style="margin-top: 2.5rem;">
            <button type="button" data-fav-id={d.id} aria-label="お気に入りに追加">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6C19 16.65 12 21 12 21z"/></svg>
            </button>
          </div>
        </aside>
      </section>
    </div>

    {related.length > 0 && (
      <section class="section-pad-sm" style="background: var(--color-bg-warm);">
        <div class="container-site">
          <p class="chapter-num">Related</p>
          <hr class="rule-accent" style="margin: 0.75rem 0 2rem;" />
          <h2 class="h-section" style="margin-bottom: 2rem;">近い季節・地域の献立</h2>
          <div class="ed-grid">
            {related.map((r) => (
              <RecipeCard
                id={r.data.id}
                title={r.data.title}
                season={r.data.season}
                region={r.data.region}
                genre={r.data.genre}
                time_min={r.data.time_min}
                hero_image={r.data.hero_image}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <style>
    .shop-add {
      width: 28px; height: 28px;
      display: inline-flex; align-items: center; justify-content: center;
      border: 1px solid var(--color-line);
      background: transparent;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--color-ink-2);
      transition: background 180ms, color 180ms, border-color 180ms;
    }
    .shop-add:hover { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }
    .shop-add.is-added { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }
  </style>

  <script>
    import { addToShopping } from '@/lib/shopping';

    function flash(btn: HTMLElement) {
      btn.classList.add('is-added');
      const old = btn.textContent;
      btn.textContent = '✓';
      setTimeout(() => {
        btn.classList.remove('is-added');
        btn.textContent = old || '+';
      }, 900);
    }

    document.querySelectorAll<HTMLButtonElement>('[data-shop-add]').forEach((btn) => {
      btn.addEventListener('click', () => {
        addToShopping({
          name: btn.dataset.shopName!,
          amount: btn.dataset.shopAmount,
          recipe_id: btn.dataset.shopRecipeId,
          recipe_title: btn.dataset.shopRecipeTitle,
        });
        flash(btn);
        (window as any).__shunrecipe?.toast?.('買い物リストへ追加しました');
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-shop-add-all]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const rows = document.querySelectorAll<HTMLButtonElement>('[data-shop-add]');
        let n = 0;
        rows.forEach((r) => {
          addToShopping({
            name: r.dataset.shopName!,
            amount: r.dataset.shopAmount,
            recipe_id: r.dataset.shopRecipeId,
            recipe_title: r.dataset.shopRecipeTitle,
          });
          n++;
        });
        (window as any).__shunrecipe?.toast?.(`${n}件を買い物リストへ追加`);
      });
    });
  </script>
</BaseLayout>
