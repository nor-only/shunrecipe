---
import BaseLayout from '@layouts/BaseLayout.astro';
import RecipeCard from '@components/ui/RecipeCard.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { recipes, getRecipeById, getRecipesForVegetable } from '@data/recipes';
import { seasonNames, getVegetableById } from '@data/vegetables';
import { getRegionName } from '@data/regions';

export function getStaticPaths() {
  return recipes.map(r => ({
    params: { id: r.id },
  }));
}

const { id } = Astro.params;
const recipe = getRecipeById(id!);

if (!recipe) {
  return Astro.redirect('/recipes/');
}

const seasonInfo = seasonNames[recipe.season];
const veg = getVegetableById(recipe.mainVegetable);
const relatedRecipes = getRecipesForVegetable(recipe.mainVegetable)
  .filter(r => r.id !== recipe.id)
  .slice(0, 3);
---

<BaseLayout title={`${recipe.title} | SHUNRECIPE`} darkHero={true}>
  <article class="pt-32 pb-20">
    <div class="container-narrow">
      <!-- Back link -->
      <a
        href="/recipes/"
        class="inline-flex items-center gap-2 text-[0.75rem] font-semibold text-text-muted hover:text-text transition-colors mb-10 tracking-wider uppercase font-outfit"
      >
        <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
        Back to recipes
      </a>

      <!-- Header -->
      <header class="mb-12 max-w-3xl">
        <div class="flex items-center gap-4 mb-6 reveal">
          <span class:list={['season-badge', `season-badge-${recipe.season}`]}>
            {seasonInfo.jp}
          </span>
          {veg && (
            <a href={`/vegetables/${veg.id}/`} class="text-[0.75rem] tracking-wider uppercase font-outfit text-text-muted hover:text-accent transition-colors">
              主役: {veg.name}
            </a>
          )}
        </div>
        <h1 class="font-heading text-[var(--font-size-display)] mb-4 reveal leading-[1.3]">
          {recipe.title}
        </h1>
        <p class="text-[1.0625rem] text-text-muted reveal leading-relaxed">{recipe.subtitle}</p>
      </header>

      <!-- Hero Image -->
      <div class="recipe-hero-image clip-reveal mb-8 relative">
        <img
          src={recipe.image}
          alt={recipe.title}
        />
        <button
          type="button"
          class="fav-toggle absolute top-5 right-5 z-10"
          data-fav-id={recipe.id}
          aria-label="お気に入りに追加"
        >
          <span class="material-symbols-outlined">favorite</span>
        </button>
      </div>

      <!-- Meta strip -->
      <div class="flex flex-wrap items-stretch mb-16 reveal">
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Time</span>
          <span class="recipe-meta-value">{recipe.time}<span class="text-[0.75rem] font-medium text-text-muted ml-1">min</span></span>
        </div>
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Calories</span>
          <span class="recipe-meta-value">{recipe.calories}<span class="text-[0.75rem] font-medium text-text-muted ml-1">kcal</span></span>
        </div>
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Servings</span>
          <span class="recipe-meta-value">{recipe.servings}<span class="text-[0.75rem] font-medium text-text-muted ml-1">人分</span></span>
        </div>
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Difficulty</span>
          <span class="recipe-meta-value text-[0.9375rem]">{recipe.difficulty}</span>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="grid lg:grid-cols-3 gap-8 mb-20">
        <!-- Ingredients (sidebar) -->
        <div class="lg:col-span-1">
          <div class="detail-section sticky top-28 reveal">
            <h3 class="detail-section-title">
              <span class="material-symbols-outlined" style="font-size:16px">kitchen</span>
              Ingredients · 材料
            </h3>
            {recipe.ingredients.map(i => (
              <div class="ingredient-row">
                <span>{i.name}</span>
                <span>{i.amount}</span>
              </div>
            ))}
            <p class="mt-5 text-[0.75rem] text-text-subtle font-mono-num">
              {recipe.servings}人分の分量
            </p>
          </div>
        </div>

        <!-- Steps -->
        <div class="lg:col-span-2">
          <div class="detail-section mb-6 reveal">
            <h3 class="detail-section-title">
              <span class="material-symbols-outlined" style="font-size:16px">restaurant</span>
              Method · 作り方
            </h3>
            {recipe.steps.map((step, idx) => (
              <div class="recipe-step">
                <span class="recipe-step-num">{String(idx + 1).padStart(2, '0')}</span>
                <p>{step}</p>
              </div>
            ))}
          </div>

          <!-- Tips -->
          <div class="tips-card reveal">
            <p class="tips-card-title">
              <span class="material-symbols-outlined" style="font-size:16px">auto_awesome</span>
              CHEF'S TIPS · 美味しく作るコツ
            </p>
            <p>{recipe.tips}</p>
          </div>
        </div>
      </div>

      {/* Linked Vegetable */}
      {veg && (
        <a
          href={`/vegetables/${veg.id}/`}
          class="detail-section flex items-center gap-6 hover:border-accent hover:shadow-hover transition-all mb-20 reveal"
        >
          <span class="text-4xl">{veg.emoji}</span>
          <div class="flex-1">
            <p class="text-[0.6875rem] font-outfit tracking-[0.2em] uppercase text-text-subtle font-semibold">Main Ingredient</p>
            <p class="font-heading text-xl mt-1">{veg.name}</p>
            <p class="text-[0.75rem] text-text-muted font-outfit tracking-wide">{veg.nameEn}</p>
            <div class="flex flex-wrap gap-1.5 mt-3">
              {veg.regions.slice(0, 5).map(r => (
                <span class="region-pill">{getRegionName(r)}</span>
              ))}
            </div>
          </div>
          <span class="material-symbols-outlined text-text-subtle">arrow_forward</span>
        </a>
      )}

      {/* Related Recipes */}
      {relatedRecipes.length > 0 && (
        <div>
          <SectionHeading
            enTitle="Related"
            title="この野菜の他のレシピ"
          />
          <div class="grid-recipes stagger-children">
            {relatedRecipes.map(r => (
              <RecipeCard recipe={r} />
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
