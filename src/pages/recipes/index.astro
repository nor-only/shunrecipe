---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import ChapterHeading from '@components/ui/ChapterHeading.astro';
import RecipeCard from '@components/ui/RecipeCard.astro';
import FilterBar from '@components/ui/FilterBar.astro';
import { getCollection } from 'astro:content';
import { regionName, prefecturesOfRegion } from '@/data/regions';

const recipes = await getCollection('recipes');
const vegetables = await getCollection('vegetables');
const vegMap = new Map(vegetables.map((v) => [v.data.slug, v.data]));

const entries = recipes.map((r) => {
  const region_name = r.data.region ? regionName(r.data.region) : undefined;
  const defaultPrefs = r.data.region ? prefecturesOfRegion(r.data.region) : [];
  const vegetable_names = r.data.vegetable
    .map((slug) => vegMap.get(slug)?.name_ja)
    .filter((n): n is string => Boolean(n));
  // タグに都道府県名が含まれていれば prefecture として抽出
  const prefTags = (r.data.tags ?? []).filter((t) => defaultPrefs.includes(t));
  return {
    id: r.data.id,
    title: r.data.title,
    subtitle: r.data.subtitle,
    season: r.data.season,
    region: r.data.region,
    region_name,
    prefecture: r.data.prefecture,
    prefectures: r.data.prefecture ? [r.data.prefecture, ...defaultPrefs] : defaultPrefs,
    vegetable: r.data.vegetable,
    vegetable_names,
    time_min: r.data.time_min,
    genre: r.data.genre,
    tags: r.data.tags,
    story: r.data.story,
    _prefTags: prefTags,
  };
});
---
<BaseLayout title="レシピ総覧 — SHUNRECIPE" description="季節・地域・ジャンル・調理時間で絞り込める、旬野菜のプレミアムレシピ総覧。" ogImage="/og/recipes.png">
  <header class="section-pad-sm" style="padding-top: clamp(6rem, 14vw, 10rem);">
    <div class="container-site">
      <ChapterHeading
        num="All Recipes"
        title="季節と地域で、献立を編む。"
        caption="All recipes — filter by season, region, genre, time"
        lede="和洋中・エスニック・創作まで、旬の素材を中心に据えたレシピを収録。URLで絞り込み状態を共有できます。"
      />
    </div>
  </header>

  <section class="container-site">
    <FilterBar mode="recipes" />
  </section>

  <section class="section-pad-sm">
    <div class="container-site">
      <div class="ed-grid" data-filter-grid>
        {recipes.map((r, i) => (
          <div data-filter-data={JSON.stringify(entries[i])}>
            <RecipeCard
              id={r.data.id}
              title={r.data.title}
              season={r.data.season}
              region={r.data.region}
              genre={r.data.genre}
              time_min={r.data.time_min}
              hero_image={r.data.hero_image}
            />
          </div>
        ))}
      </div>
      <div data-filter-empty style="display:none; padding: 3rem 0;">
        <p style="font-family: var(--font-serif-jp); color: var(--color-ink-2);">該当なし。近いシーズンで編集部のおすすめ：</p>
        <ul data-filter-suggest style="list-style:none; padding:0; margin-top:1rem; display:flex; flex-direction:column; gap: 0.75rem;"></ul>
      </div>
    </div>
  </section>

  <script>
    import '@/scripts/filter.ts';
  </script>
</BaseLayout>
