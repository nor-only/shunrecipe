---
import BaseLayout from '@layouts/BaseLayout.astro';
import RecipeCard from '@components/ui/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { regionName } from '@data/regions';

export async function getStaticPaths() {
  const vegetables = await getCollection('vegetables');
  return vegetables.map((v) => ({ params: { id: v.data.slug }, props: { vegetable: v } }));
}

const { vegetable } = Astro.props;
const d = vegetable.data;
const story = vegetable.body?.trim() || '';
const allRecipes = await getCollection('recipes');

const related = allRecipes.filter((r) =>
  r.data.vegetable.includes(d.slug) || d.related_recipes.includes(r.data.id)
);
---
<BaseLayout
  title={`${d.name_ja} — ${d.name_en} — SHUNRECIPE`}
  description={story.slice(0, 120) || `${d.name_ja}の旬・産地・在来種・関連レシピ。`}
  ogImage={`/og/veg-${d.slug}.png`}
>
  <article>
    <div class="container-site">
      <nav style="padding-top: clamp(6rem, 12vw, 9rem); display: flex; gap: 1.5rem; align-items: baseline;">
        <a href="/seasonal/" class="ed-link" style="font-size: 0.8125rem;"><span class="arrow">←——</span> 四季の図鑑</a>
        <span class="meta-inline">Vegetable · {d.name_en}</span>
      </nav>

      <header class="recipe-hero">
        <div>
          <p class="chapter-num">Volume I · {d.slug.toUpperCase()}</p>
          <hr class="rule-accent" style="margin: 1rem 0;" />
          <h1 class="display-2" style="margin-bottom: 0.75rem;">{d.name_ja}</h1>
          <p class="caption-en" style="font-size: 1rem;">{d.name_en}</p>
          {story && (
            <p style="margin-top: 1.75rem; font-family: var(--font-serif-jp); line-height: 2; color: var(--color-ink-2); max-width: 52ch;">
              {story}
            </p>
          )}
        </div>
        {d.image && (
          <div class="media">
            <img src={d.image} alt={d.name_ja} />
          </div>
        )}
      </header>

      <section class="spec-list" aria-label="旬諸元">
        <div>
          <p class="k">Season</p>
          <p class="v">{d.seasons.map((s) => ({ spring:'春', summer:'夏', autumn:'秋', winter:'冬' }[s])).join('・')}</p>
        </div>
        <div>
          <p class="k">Peak</p>
          <p class="v">{d.peak_months.join('・')}月</p>
        </div>
        <div>
          <p class="k">Regions</p>
          <p class="v">{d.regions.slice(0, 3).map((r) => regionName(r)).join('・')}</p>
        </div>
        <div>
          <p class="k">Nutrition</p>
          <p class="v" style="font-size: 0.9375rem;">{d.nutrition.slice(0, 3).join('・')}</p>
        </div>
      </section>

      <section class="ed-body" style="padding-block: clamp(2.5rem, 6vw, 5rem);">
        <div>
          {d.notable_cultivars.length > 0 && (
            <div>
              <h2 class="h-section" style="margin-bottom: 1.25rem;">在来種・ブランド産地</h2>
              <hr class="rule-accent" style="margin-bottom: 1.5rem;" />
              <ul style="list-style:none; padding:0; margin:0; display:grid; gap: 1rem;">
                {d.notable_cultivars.map((c) => (
                  <li style="display:grid; grid-template-columns: auto 1fr; gap: 1rem; padding-bottom: 1rem; border-bottom: 0.5px solid var(--color-line);">
                    <p style="font-family: var(--font-serif-jp); font-weight: 500;">{c.name}</p>
                    <p style="font-family: var(--font-serif-jp); color: var(--color-ink-2); font-size: 0.9375rem;">{c.region}</p>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {d.pairings && d.pairings.length > 0 && (
            <div style="margin-top: 2.5rem;">
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Pairings</p>
              <p style="font-family: var(--font-serif-jp); line-height: 1.9;">{d.pairings.join(' / ')}</p>
            </div>
          )}
        </div>

        <aside>
          {d.storage && (
            <div>
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Storage</p>
              <p style="font-family: var(--font-serif-jp); line-height: 1.95;">{d.storage}</p>
            </div>
          )}
          {d.aliases && d.aliases.length > 0 && (
            <div style="margin-top: 2rem;">
              <p class="chapter-num" style="margin-bottom: 0.75rem;">Aliases</p>
              <p style="font-family: var(--font-serif-jp);">{d.aliases.join(' / ')}</p>
            </div>
          )}
        </aside>
      </section>
    </div>

    {related.length > 0 && (
      <section class="section-pad-sm" style="background: var(--color-bg-warm);">
        <div class="container-site">
          <p class="chapter-num">Recipes using {d.name_en}</p>
          <hr class="rule-accent" style="margin: 0.75rem 0 2rem;" />
          <h2 class="h-section" style="margin-bottom: 2rem;">{d.name_ja}を使う献立</h2>
          <div class="ed-grid">
            {related.map((r) => (
              <RecipeCard
                id={r.data.id}
                title={r.data.title}
                season={r.data.season}
                region={r.data.region}
                genre={r.data.genre}
                time_min={r.data.time_min}
                hero_image={r.data.hero_image}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
