---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import ChapterHeading from '@components/ui/ChapterHeading.astro';
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
const serialized = recipes.map((r) => ({
  id: r.data.id,
  title: r.data.title,
  season: r.data.season,
  region: r.data.region,
  genre: r.data.genre,
  time_min: r.data.time_min,
  hero_image: r.data.hero_image,
}));
---
<BaseLayout title="お気に入り — SHUNRECIPE" description="ブラウザに保存された、あなたのレシピ本。" ogImage="/og/favorites.png">
  <header class="section-pad-sm" style="padding-top: clamp(6rem, 14vw, 10rem);">
    <div class="container-site">
      <ChapterHeading
        num="Your Shelf"
        title="あなたの手元に、一冊のレシピ本を。"
        caption="Your personal shelf"
        lede="ブラウザに保存された、あなたが選んだ献立を並べます。保存先はこの端末のみです。"
      />
    </div>
  </header>

  <section class="section-pad-sm">
    <div class="container-site">
      <div id="fav-grid" class="ed-grid"></div>
      <div id="fav-empty" style="padding: 3rem 0;">
        <p style="font-family: var(--font-serif-jp); color: var(--color-ink-2);">
          まだ何も選ばれていません。各レシピのページで、お気に入りに追加してください。
        </p>
        <a href="/recipes/" class="ed-link" style="margin-top: 1.25rem; display: inline-block;">レシピ総覧へ<span class="arrow">——→</span></a>
      </div>
    </div>
  </section>

  <script define:vars={{ serialized }}>
    const recipesById = new Map(serialized.map((r) => [r.id, r]));
    const grid = document.getElementById('fav-grid');
    const empty = document.getElementById('fav-empty');
    function render() {
      let favs = [];
      try { favs = JSON.parse(localStorage.getItem('shunrecipe.favorites') || '[]'); } catch {}
      grid.innerHTML = '';
      const seasonJp = { spring: '春', summer: '夏', autumn: '秋', winter: '冬' };
      const available = favs.filter((id) => recipesById.has(id));
      if (available.length === 0) { empty.style.display = ''; return; }
      empty.style.display = 'none';
      for (const id of available) {
        const r = recipesById.get(id);
        const a = document.createElement('a');
        a.href = `/recipes/${r.id}/`;
        a.className = 'ed-card';
        a.innerHTML = `
          <div class="media"><img src="${r.hero_image}" alt="${r.title}" loading="lazy"/></div>
          <div class="rule"></div>
          <div class="meta">
            <span class="genre">${r.genre} · ${r.time_min}min</span>
            <span class="genre accent-${r.season}"><span class="season-dot"></span>${seasonJp[r.season]}</span>
          </div>
          <h3 class="title">${r.title}</h3>
        `;
        grid.appendChild(a);
      }
    }
    render();
    document.addEventListener('favorites:change', render);
  </script>
</BaseLayout>
