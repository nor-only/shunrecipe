---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import ChapterHeading from '@components/ui/ChapterHeading.astro';
import VegCard from '@components/ui/VegCard.astro';
import FilterBar from '@components/ui/FilterBar.astro';
import { getCollection } from 'astro:content';

const vegetables = await getCollection('vegetables');

const entries = vegetables.map((v) => ({
  id: v.data.slug,
  name_ja: v.data.name_ja,
  name_en: v.data.name_en,
  aliases: v.data.aliases,
  seasons: v.data.seasons,
  regions: v.data.regions,
  cultivars: v.data.notable_cultivars.map((c) => c.name),
}));
---
<BaseLayout title="四季の図鑑 — SHUNRECIPE" description="全国八地域と四季で編纂した旬野菜の図鑑。" ogImage="/og/seasonal.png">
  <header class="section-pad-sm" style="padding-top: clamp(6rem, 14vw, 10rem);">
    <div class="container-site">
      <ChapterHeading
        num="Volume I — 四季の図鑑"
        title="全国八地域と、四季の旬野菜。"
        caption="A directory of seasonal vegetables"
        lede="北海道から沖縄まで、地域ごとに受け継がれてきた旬の野菜と在来種を収録します。季節・地域・キーワードで絞り込めます。"
      />
    </div>
  </header>

  <section class="container-site">
    <FilterBar mode="vegetables" placeholder="野菜名・産地・在来種名で検索（例：京野菜、丹波、雪下）" />
  </section>

  <section class="section-pad-sm">
    <div class="container-site">
      <div class="ed-grid" data-filter-grid>
        {vegetables.map((v, i) => (
          <div data-filter-data={JSON.stringify(entries[i])}>
            <VegCard
              slug={v.data.slug}
              name_ja={v.data.name_ja}
              name_en={v.data.name_en}
              seasons={v.data.seasons}
              image={v.data.image}
              region={v.data.notable_cultivars[0]?.region}
            />
          </div>
        ))}
      </div>
      <div data-filter-empty style="display:none; padding: 3rem 0;">
        <p style="font-family: var(--font-serif-jp); color: var(--color-ink-2);">該当なし。近い季節・地域でおすすめ：</p>
        <ul data-filter-suggest style="list-style:none; padding:0; margin-top:1rem; display:flex; flex-direction:column; gap: 0.75rem;"></ul>
      </div>
    </div>
  </section>

  <script>
    import '@/scripts/filter.ts';
  </script>
</BaseLayout>
